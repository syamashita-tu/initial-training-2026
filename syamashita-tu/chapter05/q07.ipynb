   "source": [
    "import numpy as np\n",
    "\n",
    "N = 16\n",
    "n = np.arange(N)\n",
    "\n",
    "x = 4*np.sin(np.pi/8*n) - 2*np.cos(3*np.pi/8*n)\n",
    "\n",
    "e1 = np.sin(np.pi/8*n)\n",
    "e2 = np.sin(3*np.pi/8*n)\n",
    "\n",
    "inner_e1 = np.sum(x * e1)\n",
    "inner_e2 = np.sum(x * e2)\n",
    "\n",
    "print(inner_e1)\n",
    "print(inner_e2)"
   ]
  }
